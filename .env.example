VITE_API_BASE_URL=http://localhost:5024

# API Gateway invoke URL for payment-report-fn (see LAMBDA_FUNCTIONS.md in the backend repo).
# Leave blank until that Lambda + API Gateway route are deployed - the Payment Reports
# admin page shows a "not configured yet" message when this is empty.
VITE_REPORTS_API_BASE_URL=

# Sentry DSN (from sentry.io project settings -> Client Keys). Safe to expose to the
# browser - it's not a secret, just an event-submission address. Leave blank to disable
# Sentry entirely (local dev).
VITE_SENTRY_DSN=

# Build-time only (Vite plugin uploads source maps during `npm run build`) - never sent to
# the browser, so these do NOT get a VITE_ prefix. See sentry.io org/project settings for
# SENTRY_ORG / SENTRY_PROJECT, and sentry.io -> Settings -> Auth Tokens for SENTRY_AUTH_TOKEN.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
